{
	"name": "job-tracker-monorepo",
	"version": "1.0.0",
	"private": true,
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"web": "npm run dev --workspace=apps/web",
		"mobile": "npm run start --workspace=apps/mobile",
		"mobile:android": "npm run android --workspace=apps/mobile",
		"mobile:ios": "npm run ios --workspace=apps/mobile",
		"build:web": "npm run build --workspace=apps/web",
		"type-check": "tsc --noEmit --project apps/web/tsconfig.json",
		"type-check:mobile": "npm run type-check --workspace=apps/mobile"
	}
}
